{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "playwriter": {
      "type": "local",
      "command": [
        "npx",
        "playwriter@latest"
      ],
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "oh-my-opencode",
    "opencode-anthropic-auth",
    "opencode-supermemory",
    "@plannotator/opencode",
  ],
  "provider": {
    "openai": {
      "name": "OpenAI",
      "models": {
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "o3": {
          "name": "o3",
          "reasoning": true
        },
        "o4-mini": {
          "name": "o4-mini",
          "reasoning": true
        },
        "codex-1": {
          "name": "Codex-1"
        }
      }
    }
  }
}
