{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    },
    "playwriter": {
      "type": "local",
      "command": [
        "npx",
        "playwriter@latest"
      ],
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-supermemory",
    "@ishaksebsib/opencode-tree@latest",
    "@plannotator/opencode@latest"
  ]
}
